# SQLite — plik bazy danych (tworzony automatycznie)
DATABASE_URL="file:./data/wielka-liga-typerow.db"

# Serwer API
PORT=3001
JWT_SECRET="change-me-to-a-long-random-string"

# Admin (tylko konto administratora — gracze rejestrują się sami)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-admin"

# Ochrona przed masową rejestracją (opcjonalne — puste = wyłączone)
# Kod wyślij grupie na Messengerze / mailu — bez niego nikt się nie zarejestruje
REGISTRATION_CODE=""
# Maks. liczba graczy (0 = bez limitu)
MAX_PLAYERS=0
# Maks. kont z jednego IP (0 = bez limitu, 2 = sensowny domyślny start)
MAX_ACCOUNTS_PER_IP=2

# API-Football (opcjonalnie — bez klucza używany jest lokalny terminarz)
API_FOOTBALL_KEY=""
API_FOOTBALL_LEAGUE_ID="1"
API_FOOTBALL_SEASON="2026"
API_FOOTBALL_AUTO_SYNC="true"
API_FOOTBALL_SYNC_INTERVAL_MS="1800000"

# Auto-sync wyników na żywo (worldcup26.ir) — co minutę, mapowanie po M1–M104
LIVE_SYNC_ENABLED="true"
LIVE_SYNC_INTERVAL_MS="60000"
WORLDCUP2026_API_URL="https://worldcup26.ir"

# Adres aplikacji (linki w e-mailach)
APP_URL="https://liga-typerow.itur.app"

# Przypomnienia e-mail ~8h przed meczem (wymaga SMTP)
EMAIL_REMINDERS_ENABLED="true"
EMAIL_REMINDER_HOURS_BEFORE="8"
EMAIL_REMINDER_POLL_INTERVAL_MS="900000"
# EMAIL_REMINDERS_DRY_RUN="true"  # loguj zamiast wysyłać (dev)

# SMTP — np. Gmail (hasło aplikacji), Brevo, Resend
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Wielka Liga Typerów <noreply@twoja-domena.pl>"
