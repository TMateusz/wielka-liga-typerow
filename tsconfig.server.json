{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": [
    "server/**/*",
    "shared/**/*",
    "prisma/seed.ts",
    "scripts/refresh-kickoff-times.ts",
    "scripts/test-email.ts",
    "scripts/simulate-live-scoring.ts",
    "scripts/simulate-knockout-scoring.ts",
    "scripts/test-scoring.ts",
    "scripts/test-all-points.ts"
  ]
}
