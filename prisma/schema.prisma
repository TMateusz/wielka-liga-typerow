generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum MatchStatus {
  PENDING
  LIVE
  FINISHED
}

enum UserRole {
  USER
  ADMIN
}

enum VirtualBetSelection {
  HOME
  DRAW
  AWAY
}

enum VirtualBetStatus {
  PENDING
  WON
  LOST
  VOID
}

model User {
  id           String       @id @default(cuid())
  firstName    String
  lastName     String
  nickname     String       @unique
  email              String?  @unique
  emailRemindersEnabled Boolean @default(true)
  password     String
  totalPoints  Float        @default(0)
  role           UserRole     @default(USER)
  hasAcceptedSimulatorTerms Boolean @default(false)
  registrationIp String?
  lastActiveAt   DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  predictions         Prediction[]
  matchResultHistory  MatchResultHistory[]
  matchRemindersSent  MatchReminderSent[]
  chatMessages        ChatMessage[]
  chatHearts          ChatHeart[]
  chatMentions        ChatMention[]
  virtualWallet       VirtualWallet?
  virtualBets         VirtualBet[]
  pushSubscriptions   PushSubscription[]

  @@index([totalPoints])
  @@index([role])
}

model ChatMessage {
  id        String    @id @default(cuid())
  userId    String
  text      String
  parentId  String?
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  parent  ChatMessage?  @relation("ChatReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies  ChatMessage[]  @relation("ChatReplies")
  hearts   ChatHeart[]
  mentions ChatMention[]

  @@index([createdAt])
  @@index([userId])
  @@index([parentId])
}

model ChatMention {
  id        String    @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, readAt])
  @@index([messageId])
}

model ChatHeart {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
}

model MatchReminderSent {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  sentAt    DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([matchId])
}

model Match {
  id            String      @id @default(cuid())
  fixtureNumber Int?        @unique
  apiFootballId Int?        @unique
  homeTeam      String
  awayTeam      String
  kickoffTime   DateTime
  homeScore       Int?
  awayScore       Int?
  knockoutWinner  String?
  status          MatchStatus @default(PENDING)
  liveClock       String?
  homeScorers     String?
  awayScorers     String?
  stage         String?
  venue         String?
  lastSyncedAt    DateTime?
  resultEnteredAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  predictions    Prediction[]
  resultHistory  MatchResultHistory[]
  remindersSent  MatchReminderSent[]
  virtualOdds    VirtualOdds?
  virtualBets    VirtualBet[]

  @@index([kickoffTime])
  @@index([status])
}

model MatchResultHistory {
  id                     String   @id @default(cuid())
  matchId                String
  adminId                String
  homeScore              Int
  awayScore              Int
  knockoutWinner         String?
  previousHomeScore      Int?
  previousAwayScore      Int?
  previousKnockoutWinner String?
  createdAt              DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  admin User  @relation(fields: [adminId], references: [id])

  @@index([matchId])
  @@index([createdAt])
}

model Prediction {
  id                 String   @id @default(cuid())
  userId             String
  matchId            String
  predictedHomeScore      Int
  predictedAwayScore      Int
  predictedKnockoutWinner String?
  pointsEarned            Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([matchId])
  @@index([userId])
}

model VirtualWallet {
  userId    String   @id
  balance   Int      @default(1000)
  updatedAt DateTime @updatedAt

  user   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledger VirtualTokenLedger[]
}

model VirtualTokenLedger {
  id           String   @id @default(cuid())
  userId       String
  amount       Int
  reason       String
  referenceKey String
  createdAt    DateTime @default(now())

  wallet VirtualWallet @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, referenceKey])
  @@index([userId, createdAt])
}

model VirtualOdds {
  matchId   String   @id
  homeOdds  Float
  drawOdds  Float
  awayOdds  Float
  source    String
  fetchedAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model VirtualBet {
  id        String              @id @default(cuid())
  userId    String
  matchId   String
  selection VirtualBetSelection
  stake     Int
  odds      Float
  status    VirtualBetStatus    @default(PENDING)
  payout    Int?
  createdAt DateTime            @default(now())
  settledAt DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([userId])
  @@index([matchId])
  @@index([status])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
